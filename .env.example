# Where to get these values:
# DISCORD_TOKEN: https://discord.com/developers/applications -> Your Application -> Bot -> Reset Token -> Copy
# CLIENT_ID: same page -> General Information -> Application ID -> Copy
# TARGET_BOT_ID: In Discord, right-click the pressure-bot -> Copy User ID
# TARGET_USER_ID: In Discord, right-click Ray (the person, not the bot) -> Copy User ID

CLIENT_ID=<YOUR_CLIENT_ID>
DISCORD_TOKEN=<YOUR_DISCORD_BOT_TOKEN>
# Optional: set these to enable automatic detection features
TARGET_BOT_ID=<TARGET_BOT_ID> # optional
TARGET_USER_ID=<TARGET_USER_ID> # optional
